# SQLite database folder (drivers, vehicles, trips persist here across restarts)
FLEET_DATA_DIR=./data

# Google Maps (required for map views)
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Optional map defaults
VITE_MAP_DEFAULT_LAT=17.3850
VITE_MAP_DEFAULT_LNG=78.4867
VITE_MAP_DEFAULT_ZOOM=12

# Base44 backend (only if using live Base44 instead of mock API)
# VITE_BASE44_APP_ID=your_app_id
# VITE_BASE44_APP_BASE_URL=https://your-app.base44.app
